# custom.rules — Home SOC Lab
# These fire on your virtual network

# ── Port Scans ──────────────────────────────────────────────
alert tcp any any -> $HOME_NET any (msg:"SCAN Nmap SYN Scan Detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 5; classtype:network-scan; sid:9000001; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"SCAN Nmap NULL Scan"; flags:0; classtype:network-scan; sid:9000002; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"SCAN Nmap XMAS Scan"; flags:FPU; classtype:network-scan; sid:9000003; rev:1;)

# ── Brute Force ─────────────────────────────────────────────
alert tcp any any -> $HOME_NET 22 (msg:"BRUTE SSH Login Attempts"; flow:to_server,established; content:"SSH"; threshold:type threshold, track by_src, count 5, seconds 60; classtype:attempted-recon; sid:9000010; rev:1;)
alert tcp any any -> $HOME_NET 3389 (msg:"BRUTE RDP Login Attempts"; flow:to_server,established; threshold:type threshold, track by_src, count 5, seconds 60; classtype:attempted-recon; sid:9000011; rev:1;)

# ── Metasploit / Exploit Frameworks ─────────────────────────
alert tcp any any -> $HOME_NET any (msg:"EXPLOIT Metasploit Meterpreter Stage"; content:"|fc e8 89 00 00 00|"; classtype:shellcode-detect; sid:9000020; rev:1;)
alert tcp $HOME_NET any -> any 4444 (msg:"TROJAN Reverse Shell to Port 4444"; flow:to_server,established; classtype:trojan-activity; sid:9000021; rev:1;)
alert tcp $HOME_NET any -> any 1337 (msg:"TROJAN Reverse Shell to Port 1337"; flow:to_server,established; classtype:trojan-activity; sid:9000022; rev:1;)

# ── Web Attacks ─────────────────────────────────────────────
alert http any any -> $HTTP_SERVERS any (msg:"WEB SQL Injection Attempt"; content:"' OR '1'='1"; http_uri; nocase; classtype:web-application-attack; sid:9000030; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"WEB XSS Attempt"; content:"<script>"; http_uri; nocase; classtype:web-application-attack; sid:9000031; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"WEB Directory Traversal"; content:"../"; http_uri; classtype:web-application-attack; sid:9000032; rev:1;)
alert http any any -> $HTTP_SERVERS any (msg:"SCAN Nikto Web Scanner"; content:"Nikto"; http_header; nocase; classtype:network-scan; sid:9000033; rev:1;)

# ── DNS Tunneling ────────────────────────────────────────────
alert dns any any -> any any (msg:"DNS Tunneling Suspected — Long Query"; dns.query; content:"."; pcre:"/^[a-zA-Z0-9+\/]{50,}\./"; classtype:policy-violation; sid:9000040; rev:1;)

# ── ICMP Flood ───────────────────────────────────────────────
alert icmp any any -> $HOME_NET any (msg:"ICMP Flood Detected"; threshold:type threshold, track by_src, count 100, seconds 5; classtype:denial-of-service; sid:9000050; rev:1;)

# ── ARP Spoofing ─────────────────────────────────────────────
alert arp any any -> any any (msg:"ARP Spoofing Detected"; arp.opcode:2; threshold:type threshold, track by_src, count 50, seconds 10; sid:9000060; rev:1;)
