# ============================================================
#  Home SOC Lab — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to GitHub!
# ============================================================

# ── Wazuh / ELK Passwords ───────────────────────────────────
INDEXER_PASSWORD=ChangeMe_Strong1!
DASHBOARD_PASSWORD=ChangeMe_Strong2!
API_PASSWORD=ChangeMe_Strong3!

# ── Network Interface ───────────────────────────────────────
# Your main adapter — check with: ip a   (Linux) or ipconfig (Windows)
# Example: eth0, ens33, Wi-Fi
NETWORK_INTERFACE=eth0

# ── Threat Intel APIs ───────────────────────────────────────
# VirusTotal      → https://www.virustotal.com/gui/join-us
VIRUSTOTAL_KEY=your_key_here

# AbuseIPDB       → https://www.abuseipdb.com/register
ABUSEIPDB_KEY=your_key_here

# AlienVault OTX  → https://otx.alienvault.com/api
OTX_KEY=your_key_here

# Greynoise       → https://www.greynoise.io/signup
GREYNOISE_KEY=your_key_here

# Shodan          → https://account.shodan.io
SHODAN_KEY=your_key_here

# Have I Been Pwned → https://haveibeenpwned.com/API/Key
HIBP_KEY=your_key_here

# ── Alerting ────────────────────────────────────────────────
# Telegram: message @BotFather → /newbot  to create a bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Find your chat ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Automation Engine Tuning ────────────────────────────────
POLL_INTERVAL_SECONDS=30
MIN_ALERT_LEVEL=10
SCORE_NOTIFY=50
SCORE_BLOCK=80
