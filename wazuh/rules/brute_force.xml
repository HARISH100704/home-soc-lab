<!-- wazuh/rules/brute_force.xml -->
<!-- Custom rules for detecting brute force attacks -->

<group name="brute_force,authentication,">

  <!-- SSH brute force: 5 failed logins from same IP in 2 minutes -->
  <rule id="100001" level="12" frequency="5" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip/>
    <description>SSH brute force attack detected (5+ failures in 2 min)</description>
    <group>attack,authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- RDP brute force: 5 failed logins in 2 minutes -->
  <rule id="100002" level="12" frequency="5" timeframe="120">
    <if_matched_sid>60204</if_matched_sid>
    <same_source_ip/>
    <description>RDP brute force attack detected</description>
    <group>attack,authentication_failures,</group>
  </rule>

  <!-- Web login brute force -->
  <rule id="100003" level="10" frequency="10" timeframe="60">
    <if_matched_sid>31101</if_matched_sid>
    <same_source_ip/>
    <description>Web application brute force attack detected</description>
    <group>attack,web,authentication_failures,</group>
  </rule>

  <!-- Successful login after multiple failures (possible successful brute force) -->
  <rule id="100004" level="14">
    <if_matched_sid>100001</if_matched_sid>
    <if_sid>5715</if_sid>
    <same_source_ip/>
    <description>CRITICAL: Successful login after SSH brute force — possible compromise</description>
    <group>attack,authentication_success,</group>
  </rule>

</group>
